##############################
# Private Key Configurations #
##############################=
# The key to a pre-funded deployer address
DEPLOYER_PRIVATE_KEY=

############################
# FiatToken Configurations #
############################
# The ERC20 name of the FiatToken.
TOKEN_NAME=USDC

# The ERC20 symbol of the FiatToken.
TOKEN_SYMBOL=USDC

# The fiat currency that that FiatToken represents.
TOKEN_CURRENCY=USD

# The ERC20 decimals for the FiatToken.
TOKEN_DECIMALS=6

# [OPTIONAL] The address to a deployed FiatTokenProxy contract.
# FIAT_TOKEN_PROXY_ADDRESS=

# [OPTIONAL] The address to a deployed FiatToken implementation contract.
# FIAT_TOKEN_IMPLEMENTATION_ADDRESS=

# The address of the FiatTokenProxy's admin.
PROXY_ADMIN_ADDRESS=

# [OPTIONAL] The private key of the proxy admin.
# PROXY_ADMIN_PRIVATE_KEY=

# The address of the FiatToken's owner.
OWNER_ADDRESS=

# [OPTIONAL] The private key of the FiatToken owner.
# OWNER_PRIVATE_KEY=

# The address of the MasterMinter's owner.
MASTER_MINTER_OWNER_ADDRESS=

# [OPTIONAL] The private key of the master minter owner.
# MASTER_MINTER_OWNER_PRIVATE_KEY=

# [OPTIONAL] The address of a deployed MasterMinter contract.
# MASTER_MINTER_CONTRACT_ADDRESS=

# [OPTIONAL] The address of the FiatToken's pauser. This can be a cold storage address. Defaults to the owner address.
# PAUSER_ADDRESS=

# [OPTIONAL] The address of the FiatToken's blacklister. Defaults to the owner address.
# BLACKLISTER_ADDRESS=

# [OPTIONAL] The private key of the blacklister
# BLACKLISTER_PRIVATE_KEY=

# [OPTIONAL] The address to which locked funds are sent to. Only applicable for version 2 -> 2.1 upgrades. Defaults to the owner address.
# LOST_AND_FOUND_ADDRESS=

#################################
# Minting/burning Configuration #
#################################

# [OPTIONAL] The address of a hot key minter.
# MINTER_ADDRESS=

# [OPTIONAL] The address of a hot key burner.
# BURNER_ADDRESS=

# [OPTIONAL] Minter controller role on the MasterMinter contract for configuring the minter.
# MINTER_CONTROLLER_INCREMENTER_ADDRESS=

# [OPTIONAL] Minter controller role on the MasterMinter contract for removing the minter's allowance.
# MINTER_CONTROLLER_REMOVER_ADDRESS=

# [OPTIONAL] Minter controller role on the MasterMinter contract for configuring the burner.
# BURNER_CONTROLLER_ADDRESS=

# [OPTIONAL] The initial allowance of minting for the hot minter. Specify this in normal readable units (e.g. dollars, euros, etc.).
# For instance, if you intend to set an initial allowance of 25 USDC, simply put 25 here.
# MINT_ALLOWANCE_IN_NORMAL_UNITS=

##########################
# Cold storage addresses #
##########################

# [OPTIONAL] Cold storage master minter owner.
# COLD_MASTER_MINTER_OWNER_ADDRESS=

# [OPTIONAL] Cold storage proxy admin.
# COLD_PROXY_ADMIN_ADDRESS=

# [OPTIONAL] Cold storage FiatToken owner.
# COLD_OWNER_ADDRESS=

# [OPTIONAL] Cold storage blacklister.
# COLD_BLACKLISTER_ADDRESS=

# [OPTIONAL] Cold FiatToken pauser.
# COLD_PAUSER_ADDRESS=

##########################
# Network Configurations #
##########################
# [OPTIONAL] The URL to a mainnet JSON-RPC node.
# MAINNET_RPC_URL=

# [OPTIONAL] The URL to a testnet JSON-RPC node.
# TESTNET_RPC_URL=

# The percentage to multiply gas usage estimations by (eg. 200 to double the estimation). Defaults to 130.
GAS_MULTIPLIER=110

################################
# Miscellaneous Configurations #
################################
# The file name from which to read the list of addresses to blacklist
BLACKLIST_FILE_NAME=blacklist.remote.json

# [OPTIONAL] The API key to an Etherscan flavor block explorer.
# ETHERSCAN_KEY=
