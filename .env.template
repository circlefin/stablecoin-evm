# Environment template for stablecoin-evm local development.
# Copy this file to `.env` and fill in the values.

# RPC endpoint used by Foundry/Hardhat when running scripts or tests.
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Private key for the deployer account (DO NOT COMMIT REAL KEYS).
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: Etherscan (or similar) API key for contract verification.
EXPLORER_API_KEY=YOUR_EXPLORER_API_KEY
